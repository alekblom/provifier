PORT=3002
NODE_ENV=production
BASE_URL=https://provifier.com

# Auth (set REQUIRE_API_KEY=false for self-hosted unlimited mode)
REQUIRE_API_KEY=true
SESSION_SECRET=

# Default chain: sui or solana
CHAIN=sui

# Sui — server's commit wallet
SUI_NETWORK=devnet
SUI_PRIVATE_KEY=
SUI_PACKAGE_ID=

# Solana (optional)
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_KEYPAIR_SECRET=

# EVM chains (optional)
# ETHEREUM_RPC_URL=https://eth.llamarpc.com
# ETHEREUM_PRIVATE_KEY=
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_PRIVATE_KEY=
# BASE_RPC_URL=https://mainnet.base.org
# BASE_PRIVATE_KEY=

# Alexiuz SSO + Credits
ALEXIUZ_SERVICE_KEY=
ALEXIUZ_DB_HOST=localhost
ALEXIUZ_DB_USER=
ALEXIUZ_DB_PASSWORD=
ALEXIUZ_DB_NAME=
